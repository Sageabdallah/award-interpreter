{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/upload/**",
              "ui_kits/award-interpreter/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Inter Tight|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Inter Tight, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionProvenance'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tone|key|ref|className|style|children)$/]",
        "message": "<AccordionProvenance> doesn't accept that prop. Declared props: label, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionProvenance'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sage|ochre|neutral)$/]",
        "message": "<AccordionProvenance> tone must be one of 'sage' | 'ochre' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|shape|icon|ring|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, shape, icon, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|ink|ochre|sage|red)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'ink' | 'ochre' | 'sage' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|dot)$/]",
        "message": "<Badge> shape must be one of 'pill' | 'dot'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|iconLeft|iconRight|disabled|onClick|href|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children, iconLeft, iconRight, disabled, onClick, href, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClauseRefPart'] > JSXAttribute > JSXIdentifier[name!=/^(?:ref|title|purpose|key|ref|className|style|children)$/]",
        "message": "<ClauseRefPart> doesn't accept that prop. Declared props: ref, title, purpose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Flag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|danger|icon|key|ref|className|style|children)$/]",
        "message": "<Flag> doesn't accept that prop. Declared props: children, danger, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|code|selected|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: children, icon, code, selected, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultBreakdownItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|amount|key|ref|className|style|children)$/]",
        "message": "<ResultBreakdownItem> doesn't accept that prop. Declared props: label, amount."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|caption|accent|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: icon, label, value, caption, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:ink|ochre|sage|red)$/]",
        "message": "<StatCard> accent must be one of 'ink' | 'ochre' | 'sage' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|detail|status|doneIcon|activeIcon|delay|key|ref|className|style|children)$/]",
        "message": "<StepRow> doesn't accept that prop. Declared props: label, detail, status, doneIcon, activeIcon, delay."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pending|active|done)$/]",
        "message": "<StepRow> status must be one of 'pending' | 'active' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|headerIcon|title|subtitle|accept|formats|file|optional|onFile|onRemove|uploadIcon|checkIcon|removeIcon|key|ref|className|style|children)$/]",
        "message": "<UploadCard> doesn't accept that prop. Declared props: index, headerIcon, title, subtitle, accept, formats, file, optional, onFile, onRemove, uploadIcon, checkIcon, removeIcon."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
