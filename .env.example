# Copy to .env (gitignored) and fill in. Loaded via node --env-file-if-exists=.env.

# Anthropic API key — powers /api/explain-row, /api/classify-employee and the
# seed-time gap-fill extraction (npm run seed:augment).
ANTHROPIC_API_KEY=

# Weaviate Cloud cluster (primary vector store). Leave blank to use the local
# flat index in data/rag-index only. Get these from console.weaviate.cloud →
# your cluster → REST endpoint + API key.
WEAVIATE_URL=
WEAVIATE_API_KEY=

# Payslip email dispatch (POST /api/disperse-pay, used by Disperse pay on the
# Pay Run page). Leave blank to run in dry-run mode: payslips are generated
# and the flow works, but nothing is delivered.
#
# Free options for real delivery — after filling in, verify with:
#   npm run mail:test
#
# OPTION A — your Outlook account via the Microsoft Graph API. No third party,
# and it works where Microsoft has retired password SMTP. One-time setup:
#   1. portal.azure.com -> sign in -> "App registrations" -> New registration
#        Name: anything (e.g. AXI-WFM-Demo)
#        Supported account types: "Accounts in any organizational directory
#        and personal Microsoft accounts"; leave redirect URI empty
#   2. Authentication -> Advanced settings -> "Allow public client flows"
#      -> Yes -> Save
#   3. Overview -> copy "Application (client) ID" into GRAPH_CLIENT_ID
#   4. Restart the server, then click "Connect Outlook" on the Pay Run page
#      and sign in once (or run: npm run mail:auth). The token is saved to
#      .outlook-token.json (gitignored) — every later start is automatic.
#   5. npm run mail:test
# Personal @outlook.com/@hotmail.com accounts work friction-free; a work
# mailbox (e.g. @isoftanz.com.au) works only if its admin approves the app.
GRAPH_CLIENT_ID=
# 'common' accepts both personal and work sign-ins; leave as is.
GRAPH_TENANT=common

# OPTION C — Resend HTTP API, free 100/day (resend.com -> API Keys). No SMTP
# involved; the server calls POST https://api.resend.com/emails directly.
# Without a verified domain (resend.com/domains) Resend is in testing mode:
# sender is onboarding@resend.dev and the ONLY allowed recipient is the email
# the Resend account was signed up with. SMTP (Option B) wins if both are set.
RESEND_API_KEY=

# OPTION B — any SMTP provider (takes precedence over Options A and C if set):
#   Brevo, free 300/day, no card (brevo.com -> SMTP & API -> SMTP keys):
#     SMTP_HOST=smtp-relay.brevo.com   SMTP_PORT=587
#     SMTP_USER=<login shown on that page>   SMTP_PASS=<SMTP key>
#     MAIL_FROM=<the sender address you verified in Brevo>
#   Gmail app password, ~500/day (myaccount.google.com/apppasswords,
#   needs 2-Step Verification on):
#     SMTP_HOST=smtp.gmail.com   SMTP_PORT=465
#     SMTP_USER=you@gmail.com    SMTP_PASS=<16-char app password, no spaces>
#   Personal Outlook app password (Microsoft is phasing this out — if it
#   fails with 535 even on a correct app password, use Option A):
#     SMTP_HOST=smtp-mail.outlook.com   SMTP_PORT=587
#     SMTP_USER=you@outlook.com   SMTP_PASS=<app password>
SMTP_HOST=
SMTP_PORT=587
# TLS mode is derived from the port (465 -> implicit TLS) unless set here.
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# From header (defaults to SMTP_USER; Gmail rewrites From to the account anyway)
MAIL_FROM=

# Optional overrides
# MODEL_ID=claude-sonnet-4-6
# PORT=8787
